{
  "name": "baseapi",
  "version": "1.0.0",
  "description": "Base para crear API o Back para cualquier proyecto en Node.js",
  "main": "index.js",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "start": "node ./dist/server.js",
    "dev": "tsc-watch --onSuccess \"node ./dist/server.js\"",
    "build": "tsc && pnpm run copy-templates && pnpm run copy-wallet-certificates && pnpm run copy-wallet-pass",
    "copy-wallet-certificates": "mkdir -p ./dist/utils/templates/email && cp -a ./src/utils/ticketGenerator/IOS/certificates/. ./dist/utils/ticketGenerator/IOS/certificates",
    "copy-wallet-pass": "mkdir -p ./dist/utils/ticketGenerator/IOS/model/boardingPass.pass && cp -a ./src/utils/ticketGenerator/IOS/model/boardingPass.pass/. ./dist/utils/ticketGenerator/IOS/model/boardingPass.pass",
    "copy-templates": "mkdir -p ./dist/utils/templates/email && cp -a ./src/utils/templates/email/. ./dist/utils/templates/email",
    "postinstall": "tsc && pnpm run copy-templates && pnpm run copy-wallet-certificates && pnpm run copy-wallet-pass",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "El Isi Hechicero Supremo",
  "license": "ISC",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@sendgrid/mail": "^8.1.6",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-jwt": "^8.5.1",
    "express-jwt-blacklist": "^1.1.0",
    "helmet": "^8.2.0",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.4",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "mongoose-autopopulate": "^1.1.0",
    "morgan": "^1.11.0",
    "normalize-email": "^1.1.1",
    "openai": "^6.42.0",
    "passkit-generator": "^3.5.7",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "redis": "^3.1.2",
    "remove-accents": "^0.5.0",
    "short-unique-id": "^5.3.2",
    "throng": "^5.0.0",
    "twilio": "^6.0.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/qrcode": "^1.5.6",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "tsc-watch": "^7.2.0",
    "typescript": "^5.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "mongodb-memory-server"
    ],
    "overrides": {
      "redis@<3.1.1": "^3.1.2",
      "joi@<17.13.4": "^17.13.4"
    }
  }
}
